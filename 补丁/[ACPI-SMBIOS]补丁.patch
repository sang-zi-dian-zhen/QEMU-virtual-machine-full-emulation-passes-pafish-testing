diff -uprN "a/hw/acpi/aml-build.c" "b/hw/acpi/aml-build.c"
--- "a/hw/acpi/aml-build.c"	2026-05-23 22:43:51.568503365 +0800
+++ "b/hw/acpi/aml-build.c"	2026-05-23 22:43:51.568503365 +0800
@@ -1150,6 +1150,28 @@ Aml *aml_device(const char *name_format,
     return var;
 }
 
+Aml *aml_power_resource(const char *resource_name, uint8_t system_level,
+							uint16_t resource_order)
+{
+	Aml *var = aml_bundle(0x84  /* PowerResOp */, AML_EXT_PACKAGE);
+
+	build_append_namestring(var->buf, "%s", resource_name);
+	build_append_byte(var->buf, system_level);
+	build_append_byte(var->buf, resource_order & 0xFF);
+	build_append_byte(var->buf, resource_order >> 8);
+
+	return var;
+}
+
+Aml *aml_thermal_zone(const char *tz_name)
+{
+	Aml *var = aml_bundle(0x85 /* ThermalZoneOp */, AML_EXT_PACKAGE);
+
+	build_append_namestring(var->buf, "%s", tz_name) ;
+
+	return var;
+}
