+    build_append_int_noprefix(tbl, 1 /* Desktop */, 1);
     build_append_int_noprefix(tbl, f->sci_int, 2); /* SCI_INT */
     build_append_int_noprefix(tbl, f->smi_cmd, 4); /* SMI_CMD */
     build_append_int_noprefix(tbl, f->acpi_enable_cmd, 1); /* ACPI_ENABLE */
diff -uprN "a/hw/i386/acpi-build.c" "b/hw/i386/acpi-build.c"
--- "a/hw/i386/acpi-build.c"	2026-05-23 22:43:51.564503365 +0800
+++ "b/hw/i386/acpi-build.c"	2026-05-23 22:43:51.564503365 +0800
@@ -845,6 +845,59 @@ static void build_acpi0017(Aml *table)
     aml_append(table, scope);
 }
 
+static void build_fan_device(Aml *table)
+{
+	Aml *sb_scope = aml_scope("\\_SB");
+	
+	Aml *power_res = aml_power_resource("PR01", 0, 0);
+	Aml *method = aml_method("_STA", 0, AML_SERIALIZED);
+	aml_append(method, aml_return(aml_int(0x0F)));
+	aml_append(power_res, method);
+
+	method=aml_method("_ON", 0, AML_SERIALIZED);
+	aml_append(power_res, method);
+	method=aml_method("_OFF", 0, AML_SERIALIZED);
+	aml_append(power_res, method);
+	
+	aml_append(sb_scope, power_res);
+	
+	Aml *dev = aml_device("FAN0");
+	aml_append(dev, aml_name_decl("_HID", aml_eisaid("PNP0C0B")));
+	aml_append(dev, aml_name_decl("_UID", aml_int(0)));
+
+	Aml *pkg = aml_package(1);
+	aml_append(pkg, aml_name("%s", "PR01"));
+	aml_append(dev, aml_name_decl("_PR0", pkg));
+
+    aml_append(sb_scope, dev);
+    aml_append(table, sb_scope);
+}
+
+static void build_thermal_zone(Aml *table)
+{
+	Aml *sb_scope = aml_scope("\\_SB");
+	Aml *tz = aml_thermal_zone("TZ00");
+
+	Aml *method = aml_method("_AC0", 0, AML_NOTSERIALIZED) ;
+	aml_append(method, aml_return(aml_int(3730)));
+	aml_append(tz, method);
+
+	Aml *pkg = aml_package(1);
+	aml_append(pkg, aml_name("%s", "\\_SB.FAN0"));
+	aml_append(tz, aml_name_decl("_AL0", pkg));
+
+	method = aml_method("_TMP", 0, AML_NOTSERIALIZED) ;
+	aml_append(method, aml_return(aml_int(3630)));
+	aml_append(tz, method) ;
+
+	method = aml_method("_CRT", 0, AML_NOTSERIALIZED) ;
+	aml_append(method, aml_return(aml_int(3730)));
+	aml_append(tz, method);
+
+	aml_append(sb_scope, tz);
+	aml_append(table, sb_scope);
+}
+
 static void
 build_dsdt(GArray *table_data, BIOSLinker *linker,
            AcpiPmInfo *pm, AcpiMiscInfo *misc,
@@ -938,6 +991,9 @@ build_dsdt(GArray *table_data, BIOSLinke
         build_q35_pci0_int(dsdt);
     }
 
+	build_fan_device(dsdt);
+	build_thermal_zone(dsdt);
+
     if (misc->has_hpet) {
         build_hpet_aml(dsdt);
     }
